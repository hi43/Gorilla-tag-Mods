{
  "manifest_version": 3,
  "name": "Task Solver — Tab Agent",
  "version": "1.0.0",
  "description": "Give Claude a Chrome tab and let it read, click links, and type to complete a task.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "tabs"],
  "host_permissions": ["https://api.anthropic.com/*", "<all_urls>"],
  "action": { "default_title": "Open Task Solver Tab Agent" },
  "side_panel": { "default_path": "panel.html" },
  "background": { "service_worker": "background.js" }
}
